{
  "name": "@repo/mobile",
  "version": "1.0.0",
  "main": "./index.js",
  "scripts": {
    "start": "EXPO_UNSTABLE_MCP_SERVER=1 npx expo start",
    "start:clean": "EXPO_UNSTABLE_MCP_SERVER=1 npx expo start --clear",
    "start:go": "EXPO_UNSTABLE_MCP_SERVER=1 npx expo start --go",
    "android": "EXPO_UNSTABLE_MCP_SERVER=1 npx expo start --android",
    "ios": "EXPO_UNSTABLE_MCP_SERVER=1 npx expo start --ios",
    "web": "EXPO_UNSTABLE_MCP_SERVER=1 npx expo start --web",
    "build:ios:dev": "npx expo run:ios",
    "build:android:dev": "npx expo run:android",
    "build:ios": "eas build --platform ios --profile production",
    "build:ios:simulator": "eas build --platform ios --profile development-simulator",
    "build:android": "eas build --platform android --profile production",
    "build:eas:dev": "eas build --profile development",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prebuild": "npx expo prebuild",
    "prebuild:clean": "npx expo prebuild --clean",
    "doctor": "npx expo doctor"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@repo/domain": "*",
    "@repo/mock-data": "*",
    "@repo/theme": "*",
    "convex": "^1.34.1",
    "expo": "~54.0.31",
    "expo-asset": "~12.0.12",
    "expo-blur": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "^0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.2",
    "@babel/preset-typescript": "^7.24.7",
    "@react-native/assets-registry": "^0.83.1",
    "@react-native/typescript-config": "^0.83.1",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.11",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~54.0.9",
    "expo-doctor": "^1.17.14",
    "expo-mcp": "~0.2.1",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.16",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  },
  "private": true
}
